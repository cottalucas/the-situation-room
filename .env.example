# Firebase web config. Copy this file to .env.local and fill from the Firebase
# console: Project settings, General, Your apps, Web app, SDK setup and config.
# .env.local is gitignored. Never commit real values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional but recommended for production. Enable App Check in Firebase and
# paste the reCAPTCHA Enterprise site key here.
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Local development only. Do not commit a real debug token.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Optional local-only prototype mode. Leave false for production-like testing.
VITE_ENABLE_LOCAL_PREVIEW=false

# Claude command engine. Keep false when you want no live model calls. Set true
# for local connection tests or production builds that use Firebase Functions.
VITE_ENABLE_LIVE_LLM=false

# Local connection test only. The production key is a Firebase Functions secret
# named ANTHROPIC_API_KEY, set with the Firebase CLI. Never commit a real key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Production function knobs live in functions/.env.example. The production API
# key must be set as a Firebase Functions secret, never as a Vite env var.
