# Firebase Functions runtime settings. Copy to functions/.env for local
# emulator use, or set equivalent runtime env in Firebase.
#
# Do not put ANTHROPIC_API_KEY here for production. Set it as a secret:
# firebase functions:secrets:set ANTHROPIC_API_KEY

ANTHROPIC_MODEL=claude-haiku-4-5-20251001
LLM_DAILY_REQUEST_LIMIT=200
LLM_DAILY_COST_LIMIT_USD=2

# False stores privacy-safe metadata only. True stores prompts and raw model
# responses under users/{uid}/llmTraces for deeper trace review.
LLM_STORE_RAW_TRACES=false
